# =========================================================================
# DVGA-Node (Damn Vulnerable GraphQL Lab) - Environment Configuration
# STRICTLY EDUCATIONAL USE ONLY - DO NOT DEPLOY TO PUBLIC NETWORKS
# =========================================================================

PORT=5013

# Database configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=dvga_node

# JWT Token Secret (Intentionally weak/predictable for the JWT challenge)
JWT_SECRET=super_secret_dev_key_do_not_use_in_prod

# Lab Configuration
# SECURITY_MODE can be: VULNERABLE (default) or MITIGATED (secure resolvers)
SECURITY_MODE=VULNERABLE

# LEARNING_MODE can be: BEGINNER (full guidance & hints) or EXPERT (minimal hints)
LEARNING_MODE=BEGINNER
